---
import { css } from "../../../styled-system/css";
import { FOOTER } from "../../lib/sectionText";

const footerStyles = css({
  paddingBottom: "1rem",
  textAlign: "center",
});

const smallStyles = css({
  fontSize: "0.6rem",
  pc: {
    fontSize: "0.8rem",
  },
});
---

<footer class={footerStyles}>
  <small class={smallStyles}>
    {FOOTER}
  </small>
</footer>
