---
import "../styles/index.css";

export interface Props {
  title?: string;
  description?: string;
  fontChars?: string;
}

const {
  title = "Shigetaka Shirouchi",
  description = "I'm a Front-End Engineer.",
  fontChars,
} = Astro.props;

const sawarabiUrl = fontChars
  ? `https://fonts.googleapis.com/css?family=Sawarabi+Gothic&text=${encodeURIComponent(fontChars)}&display=swap`
  : `https://fonts.googleapis.com/css?family=Sawarabi+Gothic&display=swap`;

// Fetch at build time to inline CSS and extract woff2 URL for preload
let sawarabiCss = "";
let sawarabiWoff2Url = "";
try {
  const res = await fetch(sawarabiUrl, {
    headers: {
      "User-Agent":
        "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36",
    },
  });
  sawarabiCss = await res.text();
  const match = sawarabiCss.match(/url\(([^)]+)\)\s+format\(['"]?woff2['"]?\)/);
  if (match) sawarabiWoff2Url = match[1];
} catch {
  // fall back to link tag
}

const siteUrl = "https://shgtkshruch.com";
const ogImage = `${siteUrl}/ogp.png`;
const GA_TRACKING_ID = import.meta.env.PUBLIC_GA_TRACKING_ID || "";
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:description" content={description} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@shgtkshruch" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fonts -->
    {sawarabiWoff2Url && <link rel="preload" href={sawarabiWoff2Url} as="font" type="font/woff2" crossorigin="anonymous" />}
    {sawarabiCss
      ? <Fragment set:html={`<style>${sawarabiCss}</style>`} />
      : <link href={sawarabiUrl} rel="stylesheet" />}

    <!-- Google Analytics -->
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_TRACKING_ID}`}></script>
    <script is:inline define:vars={{ GA_TRACKING_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', GA_TRACKING_ID);
    </script>

    <!-- Theme initialization (FOUC prevention) -->
    <script is:inline>
      const theme = localStorage.getItem('theme') ||
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

      const colors = {
        light: { primary: '#222', bg: '#fff', accent: 'red' },
        dark: { primary: '#dee1e8', bg: '#161725', accent: '#ef40b8' }
      };

      document.documentElement.style.setProperty('--primary-color', colors[theme].primary);
      document.documentElement.style.setProperty('--bg-color', colors[theme].bg);
      document.documentElement.style.setProperty('--accent-color', colors[theme].accent);
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
