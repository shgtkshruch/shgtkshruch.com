    "@fontsource/inconsolata": "^5.2.8",
    "astro": "^6.2.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-typist-component": "^1.1.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@pandacss/dev": "^1.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "24.12.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.48.0",
